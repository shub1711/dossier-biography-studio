# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM provider: google (dev) | openai (demo)
LLM_PROVIDER=google


# OpenAI
OPENAI_API_KEY=
OPENAI_WEBHOOK_SECRET=

# Diffbot (URL mode)
DIFFBOT_API_KEY=your-diffbot-key

# Set true when Supabase Edge Functions are deployed (default: Next.js API routes)
NEXT_PUBLIC_USE_SUPABASE_FUNCTIONS=false
